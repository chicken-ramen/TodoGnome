<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="todognome">
  <schema id="org.gnome.shell.extensions.todognome" path="/org/gnome/shell/extensions/todognome/">
    <key name="refresh-interval" type="i">
      <default>30</default>
      <summary>Refresh interval</summary>
      <description>Seconds between status updates</description>
      <range min="5" max="300"/>
    </key>
    <key name="show-critical-only" type="b">
      <default>false</default>
      <summary>Show only critical tasks</summary>
      <description>Only show indicator when there are critical priority tasks</description>
    </key>
    <key name="launch-command" type="s">
      <default>"todognome"</default>
      <summary>Application command</summary>
      <description>Command to launch the TodoGnome application</description>
    </key>
  </schema>
</schemalist>